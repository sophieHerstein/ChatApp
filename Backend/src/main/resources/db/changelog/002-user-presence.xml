<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-add-user-last-seen-at" author="sophie">
        <addColumn tableName="app_user">
            <column name="last_seen_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

    <changeSet id="005-initialize-user-last-seen-at" author="sophie">
        <update tableName="app_user">
            <column name="last_seen_at" valueComputed="created_at"/>
            <where>last_seen_at IS NULL</where>
        </update>

        <addNotNullConstraint
                tableName="app_user"
                columnName="last_seen_at"
                columnDataType="TIMESTAMP"/>
    </changeSet>

</databaseChangeLog>
