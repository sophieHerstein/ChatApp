<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="001-init_001" author="sophie">
        <createTable tableName="app_user">
            <column name="id" type="UUID">
                <constraints primaryKey="true"
                             nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false"
                             unique="true"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="profile_image_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-contact" author="sophie">
            <createTable tableName="contact">
                <column name="id" type="UUID">
                    <constraints primaryKey="true" nullable="false"/>
                </column>
                <column name="owner_user_id" type="UUID">
                    <constraints nullable="false"/>
                </column>
                <column name="contact_user_id" type="UUID">
                    <constraints nullable="false"/>
                </column>
                <column name="created_at" type="TIMESTAMP">
                    <constraints nullable="false"/>
                </column>
            </createTable>
            <addForeignKeyConstraint
                    baseTableName="contact"
                    baseColumnNames="owner_user_id"
                    referencedTableName="app_user"
                    referencedColumnNames="id"
                    constraintName="fk_contact_owner_user"/>
            <addForeignKeyConstraint
                    baseTableName="contact"
                    baseColumnNames="contact_user_id"
                    referencedTableName="app_user"
                    referencedColumnNames="id"
                    constraintName="fk_contact_contact_user"/>
            <addUniqueConstraint
                    tableName="contact"
                    columnNames="owner_user_id, contact_user_id"
                    constraintName="uk_contact_owner_contact"/>
    </changeSet>
    <changeSet id="003-create-chat" author="sophie">

        <createTable tableName="chat">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="chat_participant">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="chat_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="chat_message">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="chat_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="sender_user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="read" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="chat_participant"
                baseColumnNames="chat_id"
                referencedTableName="chat"
                referencedColumnNames="id"
                constraintName="fk_chat_participant_chat"/>
        <addForeignKeyConstraint
                baseTableName="chat_participant"
                baseColumnNames="user_id"
                referencedTableName="app_user"
                referencedColumnNames="id"
                constraintName="fk_chat_participant_user"/>
        <addForeignKeyConstraint
                baseTableName="chat_message"
                baseColumnNames="chat_id"
                referencedTableName="chat"
                referencedColumnNames="id"
                constraintName="fk_chat_message_chat"/>
        <addForeignKeyConstraint
                baseTableName="chat_message"
                baseColumnNames="sender_user_id"
                referencedTableName="app_user"
                referencedColumnNames="id"
                constraintName="fk_chat_message_sender"/>
        <addUniqueConstraint
                tableName="chat_participant"
                columnNames="chat_id, user_id"
                constraintName="uk_chat_participant_chat_user"/>
        <createIndex
                tableName="chat_message"
                indexName="idx_chat_message_chat_created_at">
            <column name="chat_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>
    <changeSet id="004-add-user-last-seen-at" author="sophie">
        <addColumn tableName="app_user">
            <column name="last_seen_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

    <changeSet id="005-initialize-user-last-seen-at" author="sophie">
        <update tableName="app_user">
            <column name="last_seen_at" valueComputed="created_at"/>
            <where>last_seen_at IS NULL</where>
        </update>

        <addNotNullConstraint
                tableName="app_user"
                columnName="last_seen_at"
                columnDataType="TIMESTAMP"/>
    </changeSet>

    <changeSet id="006-add-chat-message-client-id" author="sophie">
        <addColumn tableName="chat_message">
            <column name="client_message_id" type="UUID"/>
        </addColumn>

        <addUniqueConstraint
                tableName="chat_message"
                columnNames="client_message_id"
                constraintName="uk_chat_message_client_message_id"/>
    </changeSet>

    <changeSet id="007-add-user-presence-visibility" author="sophie">
        <addColumn tableName="app_user">
            <column name="presence_visible" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>